{
  "expo": {
    "name": "App-YooYLand",
    "slug": "App-YooYLand",
    "version": "1.0.006",
    "orientation": "portrait",
    "icon": "./assets/images/yoy_app_icon.png",
    "scheme": "appyooyland",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "buildNumber": "8",
      "bundleIdentifier": "com.yooyland.wallet",
      "infoPlist": {
        "NSContactsUsageDescription": "Contacts are used to find and add friends.",
        "NSCameraUsageDescription": "Camera is used for QR scanning and verification.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used to select or upload images.",
        "NSPhotoLibraryAddUsageDescription": "Photo library is used to save images created in the app.",
        "NSMicrophoneUsageDescription": "Microphone may be used when recording video in certain features.",
        "NSPushNotificationsUsageDescription": "Push notifications are used for messages and important alerts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/yoy_app_icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "backgroundColor": "#000000",
        "resizeMode": "contain",
        "dark": {
          "backgroundColor": "#000000"
        }
      },
      "versionCode": 2026033101,
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.yooyland.wallet",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            { "scheme": "yooy" },
            { "scheme": "appyooyland" },
            { "scheme": "yooyland" },
            { "scheme": "https", "host": "yooy.land", "pathPrefix": "/chatv2/join" }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#000000"
    },
    "androidStatusBar": {
      "backgroundColor": "#000000",
      "translucent": false,
      "barStyle": "light-content"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-apple-authentication",
      "expo-contacts",
      "./plugins/withRNEnableBundleCompressionGuard",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.0.21",
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false,
      "baseUrl": "/web"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "36784797-db25-445f-85f7-3b33aaf35f16"
      },
      "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}",
      "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "${EXPO_PUBLIC_GOOGLE_MAPS_API_KEY}",
      "EXPO_PUBLIC_YOY_ERC20_ADDRESS": "0xf999DA2B5132eA62A158dA8A82f2265A1b1d9701",
      "EXPO_PUBLIC_CHAIN": "${EXPO_PUBLIC_CHAIN}",
      "EXPO_PUBLIC_RPC_MAINNET": "${EXPO_PUBLIC_RPC_MAINNET}",
      "EXPO_PUBLIC_RPC_SEPOLIA": "${EXPO_PUBLIC_RPC_SEPOLIA}"
    }
  }
}
