rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 공통: 로그인 사용자만 쓰기 허용
    function isSignedIn() {
      return request.auth != null;
    }

    // 채팅 이미지: 본인(userId == uid) 만 쓰기, 읽기는 로그인 사용자만
    match /chat/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // QR 코드 이미지
    match /qr/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 채팅 미디어
    match /chatMedia/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 게시판 업로드: 읽기 모두 허용, 쓰기는 로그인 사용자
    match /boards/{boardId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // chatv2 방 커버/배경 (uploadRoomCoverPhotoV2 등)
    match /chatv2/rooms/{roomId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 기타 경로: 로그인 사용자만 읽기/쓰기
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}



