{
  "cli": {
    "version": ">= 16.20.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "EXPO_PUBLIC_ENV": "dev",
        "EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION": "us-central1",
        "EXPO_PUBLIC_BARCODE_ENABLED": "true"
      },
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENV": "stg",
        "EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION": "us-central1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENV": "prod",
        "EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION": "us-central1"
      },
      "ios": {
        "env": {
          "EXPO_PUBLIC_ORDER_ENABLED": "false"
        }
      }
    },
    "store": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "EXPO_PUBLIC_ENV": "prod",
        "EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION": "us-central1",
        "EXPO_PUBLIC_SOCIAL_LOGIN_ENABLED": "false",
        "EXPO_PUBLIC_ORDER_ENABLED": "true",
        "EXPO_PUBLIC_STAKING_ENABLED": "true",
        "EXPO_PUBLIC_NFT_TRADE_ENABLED": "false",
        "EXPO_PUBLIC_SHOP_ENABLED": "false",
        "EXPO_PUBLIC_BARCODE_ENABLED": "true",
        "EXPO_PUBLIC_CHAIN": "mainnet",
        "EXPO_PUBLIC_RPC_MAINNET": "https://ethereum.publicnode.com"
      },
      "ios": {
        "env": {
          "EXPO_PUBLIC_ORDER_ENABLED": "false"
        }
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6762594969",
        "appleTeamId": "788Z95G986"
      },
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./keys/play-service-account.json"
      }
    }
  }
}
