rules_version = '2';
service cloud.firestore {
  /**
   * PROD 제안안 요약 (이 파일 내용):
   * - 기본 원칙
   *   - 인증된 사용자(request.auth != null)만 접근
   *   - /users/{uid} 및 하위 컬렉션: 본인(uid == request.auth.uid)만 쓰기, 제한된 읽기
   *   - /rooms/{roomId} 및 하위 컬렉션: 멤버만 읽기/쓰기, 일부 공개 메타만 조회 허용
   *   - /claim_vouchers, /claim_notifications, /usernames, /invites: 인증 필수 + 최소 권한
   * - 실제 배포는 firebase deploy --only firestore:rules 를 실행할 때 적용됩니다.
   *   (지금은 코드 저장만 하고, 콘솔/CI에서 검토 후 배포하세요.)
   */
  match /databases/{db}/documents {
    // 공통 헬퍼
    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // chatV2 membership helper
    // roomMembers/{roomId}/members/{uid} is the source of truth for whether a user belongs to a room.
    function isRoomMember(roomId, memberUid) {
      return exists(/databases/$(db)/documents/roomMembers/$(roomId)/members/$(memberUid));
    }

    function isRoomParticipant(roomId, memberUid) {
      // Prefer roomMembers (most strict). If missing (older/legacy data), heal using canonical rooms/{roomId}.participantIds.
      return isRoomMember(roomId, memberUid) ||
        exists(/databases/$(db)/documents/users/$(memberUid)/joinedRooms/$(roomId)) ||
        (exists(/databases/$(db)/documents/rooms/$(roomId)) &&
          (get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds != null) &&
          (memberUid in (get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds)));
    }

    /** 방 문서가 있고, 요청자가 createdBy 이며 targetUid 가 participantIds 에 포함 — 최초 roomMembers/joinedRooms 배치(group/dm/secret/ttl/notice 공통) */
    function roomCreatorBootstrap(roomId, targetUid) {
      return exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.createdBy == request.auth.uid &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds != null &&
        targetUid in get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds;
    }

    /** rooms.participantIds 에 실제로 포함된 uid 가 자신의 roomMembers 행을 만들거나 settings 를 갱신할 수 있게 함 (participantIds 비어 있던 레거시 복구 전까지 권한 누락 방지) */
    function mayUpsertOwnRoomMemberFromRoomDoc(roomId, memberUid) {
      return isSignedIn() && request.auth.uid == memberUid &&
        exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds != null &&
        memberUid in get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds;
    }

    /** 방 설정 저장 시 타인의 users/{uid}/joinedRooms/{roomId} 동기화 — 두 uid 모두 rooms.participantIds 에 있으면 허용 */
    function bothInRoomParticipantIds(roomId, uidA, uidB) {
      return exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds != null &&
        uidA in get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds &&
        uidB in get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds;
    }

    /** users/{uid}/joinedRooms/{roomId} 문서 존재 — roomMembers 생성 전에도 멤버십 입증 */
    function hasJoinedRoomDoc(roomId, memberUid) {
      return exists(/databases/$(db)/documents/users/$(memberUid)/joinedRooms/$(roomId));
    }

    /** rooms.participantIds 에 포함 (문서·필드 존재 시에만 평가) */
    function inRoomsParticipantIds(roomId, memberUid) {
      return exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds is list &&
        memberUid in get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds;
    }

    function isRoomOwnerActor(roomId, actorUid) {
      return exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.createdBy == actorUid;
    }

    function isRoomAdminActor(roomId, actorUid) {
      return exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.keys().hasAll(['adminIds']) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.adminIds is list &&
        actorUid in get(/databases/$(db)/documents/rooms/$(roomId)).data.adminIds;
    }

    function roomMemberCanInviteEnabled(roomId) {
      return exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.keys().hasAll(['permissions']) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.permissions.keys().hasAll(['memberCanInvite']) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.permissions.memberCanInvite == true;
    }

    /** 배치에서 rooms.participantIds 에 초대 대상이 포함된 뒤, 방장/관리자/멤버초대 허용 멤버가 타인 roomMembers·joinedRooms 초기행 작성 */
    function actorMayInviteNewMember(roomId, invitedUid) {
      return isSignedIn() &&
        request.auth.uid != invitedUid &&
        isRoomParticipant(roomId, request.auth.uid) &&
        exists(/databases/$(db)/documents/rooms/$(roomId)) &&
        get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds is list &&
        invitedUid in get(/databases/$(db)/documents/rooms/$(roomId)).data.participantIds &&
        (
          isRoomOwnerActor(roomId, request.auth.uid) ||
          isRoomAdminActor(roomId, request.auth.uid) ||
          roomMemberCanInviteEnabled(roomId)
        );
    }

    /**
     * 본인 roomMembers/{roomId}/members/{memberUid} 문서 생성·갱신(알림·테마 등 settings)
     * — joinedRooms 또는 participantIds 또는 기존 멤버 문서로 입증 (matches 룰 누락 시에도 저장 가능)
     */
    function mayWriteOwnRoomMemberDoc(roomId, memberUid) {
      return isSignedIn() &&
        request.auth.uid == memberUid &&
        (
          isRoomMember(roomId, memberUid) ||
          hasJoinedRoomDoc(roomId, memberUid) ||
          inRoomsParticipantIds(roomId, memberUid)
        );
    }

    /** 레거시 userRoomPreferences/{uid}_{roomId} — split 은 룰/런타임에 따라 실패할 수 있어 matches 우선 */
    function ownsUserRoomPreferenceFlatDoc(docId) {
      return isSignedIn() && docId.matches('^' + request.auth.uid + '_.+');
    }

    /** 양쪽 모두 해당 방 joinedRooms 문서가 있으면 participantIds 비어 있어도 동기화 허용 */
    function bothHaveJoinedRoomDoc(roomId, uidA, uidB) {
      return hasJoinedRoomDoc(roomId, uidA) && hasJoinedRoomDoc(roomId, uidB);
    }

    // 관리자 여부는 우선 이메일 기반 (서버의 ALLOWED_ADMIN_EMAILS 와 맞추는 것을 권장)
    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.email in [
          'admin@yooyland.com',
          'jch4389@gmail.com',
          'landyooy@gmail.com'
        ]);
    }

    function requestTimeMs() {
      return request.time.seconds * 1000 + request.time.nanoseconds / 1000000;
    }

    function isUserChatSuspended(uid) {
      let p = /databases/$(db)/documents/user_chat_suspensions/$(uid);
      return exists(p) && get(p).data.suspended == true &&
        (!('untilMs' in get(p).data) || get(p).data.untilMs == null || get(p).data.untilMs == 0 ||
          get(p).data.untilMs > requestTimeMs());
    }

    function isRoomBanned(roomId, uid) {
      let p = /databases/$(db)/documents/room_bans/$(roomId)/uids/$(uid);
      return exists(p) && get(p).data.banned == true &&
        (!('untilMs' in get(p).data) || get(p).data.untilMs == null || get(p).data.untilMs == 0 ||
          get(p).data.untilMs > requestTimeMs());
    }

    /* -----------------------------
     * users 컬렉션 및 하위
     * ----------------------------- */
    match /users/{uid} {
      // 본인 문서 읽기/쓰기 허용, 다른 유저는 일부 공개 필드만 읽기 허용 가능
      allow read: if isSignedIn();
      allow write: if isMe(uid) || isAdmin();

      match /friends/{friendId} {
        // 친구 관계는 양쪽 uid 가 일치하는 경우에만 쓰기 허용
        allow read: if isMe(uid) || isSignedIn();
        allow write: if isMe(uid);
      }

      match /followers/{followerId} {
        allow read: if isMe(uid) || isSignedIn();
        allow write: if isMe(uid);
      }

      match /following/{followingId} {
        allow read: if isMe(uid) || isSignedIn();
        allow write: if isMe(uid);
      }

      match /joinedRooms/{roomId} {
        // v2 send/update writes joinedRooms for "other participants" as well.
        // - 본인 행 / 멤버끼리 동기화 / 방 생성 시 createdBy 가 참가자별 초기 행 작성
        allow read: if isSignedIn() && (isMe(uid) || isRoomParticipant(roomId, request.auth.uid));
        allow create: if isSignedIn() && !isUserChatSuspended(uid) && (
          isMe(uid) ||
          roomCreatorBootstrap(roomId, uid) ||
          bothInRoomParticipantIds(roomId, request.auth.uid, uid) ||
          actorMayInviteNewMember(roomId, uid)
        );
        allow update, delete: if isSignedIn() && (
          isMe(uid) ||
          (isRoomParticipant(roomId, uid) && isRoomParticipant(roomId, request.auth.uid)) ||
          bothInRoomParticipantIds(roomId, request.auth.uid, uid) ||
          bothHaveJoinedRoomDoc(roomId, request.auth.uid, uid)
        );
      }

      /** 방별 알림·테마 등 (본인 서브컬렉션만 — 상위 users write 와 별도로 명시) */
      match /chatRoomPrefs/{roomId} {
        allow read, write: if isMe(uid);
      }

      match /notifications/{notifId} {
        allow read: if isMe(uid);
        allow create: if isSignedIn();
        allow update, delete: if isMe(uid);
      }

      /** 내부 YOY 원장 이벤트 로그(리워드/TTL 수수료 등) — 본인만 읽기 */
      match /internalYoyEvents/{eventId} {
        allow read: if isMe(uid);
        // 클라에서 직접 쓰지 않음(Functions/Admin SDK만 작성)
        allow write: if false;
      }
    }

    /* -----------------------------
     * rooms 및 하위: 채팅방 / 메시지 / 멤버십
     * ----------------------------- */
    match /rooms/{roomId} {
      // 룸 메타 읽기: 멤버이거나 공개방(isPublic == true) 인 경우 허용
      allow read: if isSignedIn();

      // 룸 생성/수정: 로그인 사용자 (추가 제약은 서버/Cloud Functions 권장)
      allow write: if isSignedIn();

      match /messages/{messageId} {
        // 메시지 읽기/쓰기: 룸 멤버만 허용하는 것이 이상적이지만,
        // 현재 구조에서는 클라이언트에서 멤버십을 강제로 관리하므로 우선 인증만 체크
        allow read, write: if isSignedIn();
      }

      match /members/{uid} {
        allow read: if isSignedIn();
        allow write: if isMe(uid) || isAdmin();
      }
    }

    // -----------------------------
    // chatV2 collections
    // -----------------------------
    match /roomMembers/{roomId}/members/{memberUid} {
      allow read: if isSignedIn() && (isRoomParticipant(roomId, request.auth.uid) || isAdmin());
      allow create: if isSignedIn() && !isUserChatSuspended(memberUid) && !isRoomBanned(roomId, memberUid) && (
        mayWriteOwnRoomMemberDoc(roomId, memberUid) ||
        mayUpsertOwnRoomMemberFromRoomDoc(roomId, memberUid) ||
        (isRoomParticipant(roomId, request.auth.uid) && isRoomParticipant(roomId, memberUid)) ||
        roomCreatorBootstrap(roomId, memberUid) ||
        actorMayInviteNewMember(roomId, memberUid)
      );
      allow update: if isSignedIn() && !isUserChatSuspended(memberUid) && !isRoomBanned(roomId, memberUid) && (
        mayWriteOwnRoomMemberDoc(roomId, memberUid) ||
        mayUpsertOwnRoomMemberFromRoomDoc(roomId, memberUid) ||
        (isRoomParticipant(roomId, request.auth.uid) && isRoomParticipant(roomId, memberUid))
      );
      allow delete: if isSignedIn() && isRoomParticipant(roomId, request.auth.uid) && isRoomParticipant(roomId, memberUid);
    }

    match /roomMessages/{roomId}/items/{messageId} {
      allow read: if isSignedIn() && (isRoomParticipant(roomId, request.auth.uid) || isAdmin());
      allow write: if isSignedIn() && isRoomParticipant(roomId, request.auth.uid)
        && !isUserChatSuspended(request.auth.uid)
        && !isRoomBanned(roomId, request.auth.uid);
    }

    /** Written only by Cloud Functions (Admin SDK) */
    match /user_chat_suspensions/{uid} {
      allow read: if isSignedIn() && (isMe(uid) || isAdmin());
      allow write: if false;
    }

    match /room_bans/{roomId}/uids/{bannedUid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /** 내부 YOY 원장: Cloud Functions(Admin SDK)만 쓰기. 사용자는 본인 잔액 문서만 읽기. */
    match /internal_yoy_balances/{docId} {
      allow read: if isSignedIn() && docId == request.auth.uid;
      allow write: if false;
    }

    /** 거래 메모: 본인만 읽기/쓰기 (영구 보관) */
    match /users/{uid}/transactionMemos/{txId} {
      allow read, write: if isMe(uid);
    }

    match /internal_yoy_claims/{claimId} {
      allow read, write: if false;
    }

    match /internal_yoy_ops/{opId} {
      allow read, write: if false;
    }

    // 레거시 평면 선호 (마이그레이션·구버전 앱). 신규는 users/{uid}/chatRoomPrefs/{roomId} 사용
    match /userRoomPreferences/{docId} {
      allow read, write: if ownsUserRoomPreferenceFlatDoc(docId);
    }

    /* -----------------------------
     * 초대 / 유저네임 인덱스
     * ----------------------------- */
    match /invites/{inviteId} {
      allow read, write: if isSignedIn();
    }

    match /usernames/{nameId} {
      // 닉네임 인덱스: 읽기는 모두 허용, 쓰기는 로그인 사용자만
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* -----------------------------
     * 기프트(쿠폰) / 알림
     * ----------------------------- */
    /** 비생성자 수령 1건: claims +1, claimedCount +1 (레거시 문서에 claimedCount 필드 없을 때 대비) */
    function claimVoucherRecipientAppend() {
      return isSignedIn()
        && resource.data.status == 'active'
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.id == resource.data.id
        && request.resource.data.claims is list
        && resource.data.claims is list
        && request.resource.data.claims.size() == resource.data.claims.size() + 1
        && (
          (!resource.data.keys().hasAll(['claimedCount']) && request.resource.data.claimedCount == 1)
          || (resource.data.keys().hasAll(['claimedCount'])
            && request.resource.data.claimedCount == resource.data.claimedCount + 1)
        );
    }

    match /claim_vouchers/{voucherId} {
      // 읽기: 로그인 사용자 (목록/수령 확인)
      allow read: if isSignedIn();
      // 생성: 본인 이메일과 token.email 일치 시만 (클라이언트 createVoucher)
      allow create: if isSignedIn()
        && request.auth.token.email != null
        && request.resource.data.id == voucherId
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.status == 'active';
      // 수정: 관리자 / 생성자(종료·만료 등) / 단일 클레임 추가(+1) / 만료 시 status만 expired
      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.createdByEmail == request.auth.token.email
          && request.resource.data.createdByEmail == resource.data.createdByEmail
          && request.resource.data.id == resource.data.id)
        || claimVoucherRecipientAppend()
        || (isSignedIn()
          && request.resource.data.createdByEmail == resource.data.createdByEmail
          && request.resource.data.id == resource.data.id
          && request.resource.data.claims is list
          && resource.data.claims is list
          && request.resource.data.claims.size() == resource.data.claims.size() + 1
          && request.resource.data.claimedCount == resource.data.claimedCount + 1)
        || (isSignedIn()
          && resource.data.status == 'active'
          && request.resource.data.status == 'expired'
          && request.resource.data.createdByEmail == resource.data.createdByEmail
          && request.resource.data.id == resource.data.id
          && request.resource.data.claims == resource.data.claims
          && request.resource.data.claimedCount == resource.data.claimedCount);
      allow delete: if isSignedIn()
        && resource.data.createdByEmail == request.auth.token.email
        && resource.data.status == 'cancelled';
    }

    match /claim_notifications/{notifId} {
      allow read: if isSignedIn();
      // 수령 후 알림: 로그인 사용자 생성 허용 (스팸 방지: voucherId 필수)
      allow create: if isSignedIn() && request.resource.data.voucherId is string;
      allow update, delete: if isAdmin();
    }
  }
}

